# Python build artifacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
build/
dist/

# Virtual environments (host's, never the image's)
.venv
venv
env

# Editor / IDE
.vscode
.idea
*.swp

# Git
.git
.gitignore
.gitattributes
.github

# OS
.DS_Store
Thumbs.db

# Secrets - never bake these into an image. The container reads them at
# runtime via env_file in docker-compose.yml.
.env
.env.*
!.env.example

# Dev-only assets the runtime doesn't need
tests/
tools/
*.md

# Don't recursively include the Docker/ dir itself in the image
Docker/
